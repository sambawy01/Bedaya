# Bedaya server config

# AI provider: 'claude' (default) or 'ollama'
AI_PROVIDER=claude

# Required when AI_PROVIDER=claude
ANTHROPIC_API_KEY=

# Used when AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b

# Postgres connection string
DATABASE_URL=postgresql://localhost:5432/bedaya

PORT=4001
